# PS1 -------------------------------------------
# C_DIR="\[$(tput setaf 2)\]\[$(tput bold)\]"

# proxy ----------------------------------------------------------------------
# _proxy_bypass="10.96.0.0/12,192.168.59.0/24,192.168.49.0/24" # minikube
# _proxy="127.0.0.1:8002"
# _proxy_aliased=("kubectl" "terraform" "aws" "aichat")
# _proxy_name="<NAME>"

_proxy_enable-tor () {
  _proxy="socks5://127.0.0.1:9050"
  _proxy_name="tor"
  _proxy_enable
}

# ----------------------------------------------------------------------------
comp-werf-enable () {
  export WERF_BUILDAH_MODE=auto
  source <(werf completion)
}

comp-terragrunt-enable () {
  complete -o nospace -C /usr/bin/terragrunt terragrunt
}

comp-terraform-enable () {
  complete -o nospace -C terraform terraform
}

# ----------------------------------------------------------------------------
_proxy_set_aliases
